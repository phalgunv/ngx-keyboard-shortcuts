{
  "extends": "./src/test/tsconfig.spec.json",
  "compilerOptions": {
    "outDir": "./out-tsc/spec",
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
      "module": "commonjs",
      "baseUrl": "./",
      "paths": {
        "@angular/core/testing": ["./node_modules/@angular/core/types/testing"],
        "@angular/platform-browser-dynamic/testing": ["./node_modules/@angular/platform-browser-dynamic/types/testing"]
      }
  },
  "include": [
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/test.ts"
  ]
}
